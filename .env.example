# Frontend environment variables
# Set VITE_API_URL to your deployed backend URL.
# If frontend and backend are on the same Vercel project (monorepo), leave this blank
# and the axiosClient will use relative /api paths (proxied via vercel.json rewrites).
VITE_API_URL=https://your-backend.vercel.app/api

# UPI VPA (Virtual Payment Address) for fine payment QR code generation.
# Format: yourname@bank  (e.g. librarian@okaxis)
VITE_UPI_VPA=yourname@bank
